PORT=5000

# MongoDB - apna connection string yahan daalo
MONGODB_URI=mongodb://localhost:27017/flikcart

# JWT - strong secret (generated via crypto.randomBytes(32).toString('hex'))
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# Email (Resend primary, Nodemailer fallback)
# Resend: signup at https://resend.com (100 emails/day free)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM_NAME=FlikCart
EMAIL_FROM=your_verified_sender@example.com

# Nodemailer fallback (for dev/local)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Stripe - test keys use karo development mein
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Frontend URL
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
